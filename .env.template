# ==============================================================================
# StadiumOS System Environment Variable Template Configuration
# Copy this file to `.env` in root and configure environment secrets
# ==============================================================================

# Core Configurations
STADIUMOS_ENV=staging
STADIUMOS_STADIUM_ID=STAD_01_USA
STADIUMOS_LOG_LEVEL=info

# Apigee Gateway configuration
STADIUMOS_GATEWAY_PORT=8000
STADIUMOS_GATEWAY_JWT_SECRET=use-custom-secret-key-32-chars-at-least-value

# PostgreSQL Connection Credentials
STADIUMOS_PG_HOST=localhost
STADIUMOS_PG_PORT=5432
STADIUMOS_PG_DB=stadiumos_db
STADIUMOS_PG_USER=stadiumos_app_user
STADIUMOS_PG_PASS=local_dev_password_change_me

# Redis In-Memory Cache configuration
STADIUMOS_REDIS_HOST=localhost
STADIUMOS_REDIS_PORT=6379

# Apache Kafka Broker configurations
STADIUMOS_KAFKA_BROKERS=localhost:9092

# Cloud Bigtable Telemetry Log session configuration
STADIUMOS_BIGTABLE_INSTANCE_ID=stadiumos-telemetry-instance
STADIUMOS_BIGTABLE_PROJECT_ID=google-deepmind-stadiumos

# Vertex AI LLM Model & Search Configs
STADIUMOS_PROJECT_ID=google-deepmind-stadiumos
STADIUMOS_LOCATION=us-central1
STADIUMOS_GEMINI_MODEL=gemini-1.5-pro
STADIUMOS_VECTOR_INDEX_ID=stadiumos-vector-search-idx

# External Service Integrations
STADIUMOS_FIREBASE_APP_ID=stadiumos-app-firebase-ref
STADIUMOS_TWILIO_ACCOUNT_SID=twilio-sid-value-reference
STADIUMOS_TWILIO_AUTH_TOKEN=twilio-auth-token-value-reference
